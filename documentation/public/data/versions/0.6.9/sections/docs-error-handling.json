{
	"section": "Error Handling",
	"icon": "alert-triangle",
	"items": [
		{
			"name": "Error Classes",
			"description": "HTTP error classes with status codes, error codes, and structured details. Every error extends HttpError which carries a statusCode, code, and optional details.",
			"example": "  const { NotFoundError, ValidationError, createError } = require('zero-http');\r\n\n  // Throw a named error class\r\n  throw new NotFoundError('User not found');\r\n\n  // Attach a machine-readable code + details\r\n  throw new NotFoundError('Invoice missing', {\r\n      code: 'INVOICE_NOT_FOUND',\r\n      details: { invoiceId: 'INV-42' },\r\n  });\r\n\n  // Field-level validation errors\r\n  throw new ValidationError('Invalid input', {\r\n      email: 'required',\r\n      age:   'must be >= 18',\r\n  });\r\n\n  // Factory — create by status code\r\n  throw createError(503, 'Try again later');",
			"methodGroups": [
				{
					"group": "Base HttpError",
					"methods": [
						{
							"method": "HttpError",
							"signature": "new HttpError(statusCode, [message], [opts])",
							"description": "Base HTTP error class.  All framework error classes extend this.",
							"methodParams": [
								{
									"param": "statusCode",
									"type": "number",
									"required": "Yes",
									"notes": "HTTP status code."
								},
								{
									"param": "message",
									"type": "string",
									"required": "No",
									"notes": "Human-readable message."
								},
								{
									"param": "opts",
									"type": "object",
									"required": "No",
									"notes": "Additional error options."
								}
							],
							"methodOptions": [
								{
									"option": "code",
									"type": "string",
									"default": "—",
									"notes": "Machine-readable error code (e.g. 'VALIDATION_FAILED')."
								},
								{
									"option": "details",
									"type": "*",
									"default": "—",
									"notes": "Extra data (field errors, debug info, etc.)."
								}
							]
						}
					]
				},
