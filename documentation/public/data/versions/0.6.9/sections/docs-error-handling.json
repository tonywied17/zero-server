					"default": "—",
					"notes": "Custom response formatter: (err, req, isDev) => object."
				},
				{
					"option": "onError",
					"type": "function",
					"default": "—",
					"notes": "Callback on every error: (err, req, res) => void."
				}
			],
			"returns": {
				"type": "Function",
				"description": "Error-handling middleware `(err, req, res, next) => void`."
			},
			"example": "  app.use(errorHandler());                       // dev-friendly by default\r\n  app.use(errorHandler({ stack: false }));        // hide stack traces\r\n  app.use(errorHandler({\r\n      formatter: (err, req, isDev) => ({ message: err.message }),\r\n      onError: (err) => metrics.increment('errors'),\r\n  }));"
		},
		{
			"name": "debug",
			"description": "Lightweight namespaced debug logger with levels, colors, and timestamps. Enable via DEBUG env variable: DEBUG=app:*,router (supports glob patterns). Each namespace gets a unique color for easy visual scanning. Levels: trace (0), debug (1), info (2), warn (3), error (4), fatal (5), silent (6). Set level via DEBUG_LEVEL env var or programmatically.",
			"params": [
				{
					"param": "namespace",
					"type": "string",
					"required": "Yes",
					"notes": "Logger namespace (e.g. 'app:routes', 'db:queries')."
				}
			],
			"returns": {
				"type": "Function & { trace, debug, info, warn, error, fatal, enabled }",
				"description": "Logger function."
			},
			"example": "  const debug = require('zero-http').debug;\r\n  const log = debug('app:routes');\r\n\n  log.info('server started on port %d', 3000);\r\n  log.warn('deprecation notice');\r\n  log.error('failed to connect', err);\r\n  log('shorthand for debug level');\r\n\n  // Set minimum level — anything below is silenced\r\n  debug.level('warn');   // only warn, error, fatal\r\n  debug.level('silent'); // suppress all output\r\n  debug.level('trace');  // show everything\r\n  debug.level(0);        // same as 'trace'",
			"methodGroups": [
				{
