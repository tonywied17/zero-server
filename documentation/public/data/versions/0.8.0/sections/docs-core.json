		{
			"name": "Router",
			"description": "Full-featured pattern-matching router with named parameters, wildcard catch-alls, sequential handler chains, sub-router mounting, and route introspection.",
			"example": "  const { Router } = require('zero-http');\r\n\n  const api = new Router();\r\n\n  api.get('/users/:id', (req, res) => {\r\n      res.json({ id: req.params.id });\r\n  });\r\n\n  api.route('/posts')\r\n      .get((req, res) => res.json([]))\r\n      .post((req, res) => res.json({ created: true }));\r\n\n  app.use('/api', api);",
			"methodGroups": [
				{
					"group": "Core",
					"methods": [
						{
							"method": "add",
							"signature": "add(method, path, handlers, [options])",
							"description": "Register a route.",
							"methodParams": [
								{
									"param": "method",
									"type": "string",
									"required": "Yes",
									"notes": "HTTP method (e.g. 'GET') or 'ALL' to match any."
								},
								{
									"param": "path",
									"type": "string",
									"required": "Yes",
									"notes": "Route pattern."
								},
								{
									"param": "handlers",
									"type": "Function[]",
									"required": "Yes",
									"notes": "One or more handler functions `(req, res, next) => void`."
								},
								{
									"param": "options",
									"type": "object",
									"required": "No",
									"notes": "Configuration options."
								}
							],
							"methodOptions": [
								{
									"option": "secure",
									"type": "boolean",
									"default": "—",
									"notes": "When `true`, route matches only HTTPS requests;\nwhen `false`, only HTTP. Omit to match both."
								}
							]
						},
						{
							"method": "use",
							"signature": "use(prefix, router)",
							"description": "Mount a child Router under a path prefix. Requests matching the prefix are delegated to the child router with the prefix stripped from `req.url`.",
							"methodParams": [
								{
									"param": "prefix",
									"type": "string",
									"required": "Yes",
									"notes": "Path prefix (e.g. '/api')."
								},
								{
									"param": "router",
									"type": "Router",
									"required": "Yes",
									"notes": "Child router instance."
								}
							],
							"methodReturns": {
								"type": "Router",
								"description": "`this` for chaining."
							}
						},
						{
							"method": "handle",
							"signature": "handle(req, res)",
							"description": "Match an incoming request against the route table and execute the first matching handler chain.  Delegates to child routers when mounted. Sends a 404 JSON response when no route matches.",
							"methodParams": [
								{
									"param": "req",
									"type": "import('./request')",
									"required": "Yes",
									"notes": "Wrapped request."
								},
								{
									"param": "res",
									"type": "import('./response')",
									"required": "Yes",
									"notes": "Wrapped response."
								}
							]
						}
					]
				},
				{
