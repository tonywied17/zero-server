{
	"section": "Core",
	"icon": "box",
	"items": [
		{
			"name": "createApp",
			"description": "HTTP application with middleware pipeline, method-based routing, HTTPS support, built-in WebSocket upgrade handling, and route introspection. Created via `createApp()` in the public API.",
			"example": "  const { createApp } = require('zero-http');\r\n  const app = createApp();\r\n\n  app.use(logger());\r\n  app.get('/hello', (req, res) => res.json({ hello: 'world' }));\r\n  app.listen(3000);",
			"methodGroups": [
				{
					"group": "Settings",
					"methods": [
						{
							"method": "set",
							"signature": "set(key, [val])",
							"description": "Set an application setting, or retrieve one when called with a single argument. When called with two arguments, sets the value and returns `this` for chaining. When called with one argument, returns the stored value. Common settings: `'trust proxy'`, `'env'`, `'json spaces'`, `'etag'`, `'view engine'`, `'views'`, `'case sensitive routing'`.",
							"methodParams": [
								{
									"param": "key",
									"type": "string",
									"required": "Yes",
									"notes": "Setting name."
								},
								{
									"param": "val",
									"type": "*",
									"required": "No",
									"notes": "Setting value."
								}
							],
							"methodReturns": {
								"type": "* | App",
								"description": "The stored value (getter) or `this` (setter)."
							}
						},
						{
							"method": "enable",
							"signature": "enable(key)",
							"description": "Set a boolean setting to `true`.",
							"methodParams": [
								{
									"param": "key",
									"type": "string",
									"required": "Yes",
									"notes": "Setting name."
								}
							],
							"methodReturns": {
								"type": "App",
								"description": "`this` for chaining."
							}
						},
						{
							"method": "disable",
							"signature": "disable(key)",
							"description": "Set a boolean setting to `false`.",
							"methodParams": [
								{
									"param": "key",
									"type": "string",
									"required": "Yes",
									"notes": "Setting name."
								}
							],
							"methodReturns": {
								"type": "App",
								"description": "`this` for chaining."
							}
						},
						{
							"method": "enabled",
							"signature": "enabled(key)",
							"description": "Check if a setting is truthy.",
							"methodParams": [
								{
									"param": "key",
									"type": "string",
									"required": "Yes",
									"notes": "Setting name."
								}
							],
							"methodReturns": {
								"type": "boolean",
								"description": "`true` if the setting is truthy."
							}
						},
						{
							"method": "disabled",
							"signature": "disabled(key)",
							"description": "Check if a setting is falsy.",
							"methodParams": [
								{
									"param": "key",
									"type": "string",
									"required": "Yes",
									"notes": "Setting name."
								}
							],
							"methodReturns": {
								"type": "boolean",
								"description": "`true` if the setting is falsy."
							}
						}
					]
				},
				{
					"group": "Middleware",
					"methods": [
						{
							"method": "use",
							"signature": "use(pathOrFn, [fn])",
							"description": "Register middleware or mount a sub-router. - `use(fn)` — global middleware applied to every request. - `use('/prefix', fn)` — path-scoped middleware (strips the prefix before calling `fn` so downstream sees relative paths). - `use('/prefix', router)` — mount a Router sub-app at the given prefix.",
							"methodParams": [
								{
									"param": "pathOrFn",
									"type": "string | Function",
									"required": "Yes",
									"notes": "A path prefix string, or middleware function."
								},
								{
									"param": "fn",
									"type": "Function | Router",
									"required": "No",
									"notes": "Middleware function or Router when first arg is a path."
								}
							]
						},
						{
							"method": "onError",
							"signature": "onError(fn)",
							"description": "Register a global error handler. The handler receives `(err, req, res, next)` and is invoked whenever a middleware or route handler throws or passes an error to `next(err)`.",
							"methodParams": [
								{
									"param": "fn",
									"type": "Function",
									"required": "Yes",
									"notes": "Error-handling function `(err, req, res, next) => void`."
								}
							]
						},
						{
							"method": "param",
							"signature": "param(name, fn)",
							"description": "Register a parameter pre-processing handler. Runs before route handlers for any route containing a `:name` parameter.",
							"methodParams": [
								{
									"param": "name",
									"type": "string",
									"required": "Yes",
									"notes": "Parameter name."
								},
								{
									"param": "fn",
									"type": "Function",
									"required": "Yes",
									"notes": "`(req, res, next, value) => void`."
								}
							],
							"methodReturns": {
								"type": "App",
								"description": "`this` for chaining."
							}
						}
					]
				},
				{
					"group": "Request Handling",
					"methods": [
						{
							"method": "handle",
							"signature": "handle(req, res)",
							"description": "Core request handler.  Wraps the raw Node `req`/`res` in `Request`/`Response` wrappers, runs the middleware pipeline, then falls through to the router.",
							"methodParams": [
								{
									"param": "req",
									"type": "import('http').IncomingMessage",
									"required": "Yes",
									"notes": "Raw Node request."
								},
								{
									"param": "res",
									"type": "import('http').ServerResponse",
									"required": "Yes",
									"notes": "Raw Node response."
								}
							]
						}
					]
				},
				{
					"group": "Server Lifecycle",
					"methods": [
						{
							"method": "listen",
							"signature": "listen([port], [opts], [cb])",
							"description": "Start listening for HTTP or HTTPS connections.",
							"methodParams": [
								{
									"param": "port",
									"type": "number",
									"required": "No",
									"notes": "Port number to bind."
								},
								{
									"param": "opts",
									"type": "object | Function",
									"required": "No",
									"notes": "TLS options for HTTPS, or a callback."
								},
								{
									"param": "cb",
									"type": "Function",
									"required": "No",
									"notes": "Callback invoked once the server is listening."
								}
							],
							"methodOptions": [
								{
									"option": "key",
									"type": "Buffer | string",
									"default": "—",
									"notes": "Private key for TLS."
								},
								{
									"option": "cert",
									"type": "Buffer | string",
									"default": "—",
									"notes": "Certificate for TLS."
								},
								{
									"option": "pfx",
									"type": "Buffer | string",
									"default": "—",
									"notes": "PFX/PKCS12 bundle (alternative to key+cert)."
								}
							],
							"methodReturns": {
								"type": "import('http').Server | import('https').Server",
								"description": "The underlying server."
							}
						},
						{
							"method": "close",
							"signature": "close([cb])",
							"description": "Gracefully close the server, stopping new connections.",
							"methodParams": [
								{
									"param": "cb",
									"type": "Function",
									"required": "No",
									"notes": "Callback invoked once the server has closed."
								}
							]
						}
					]
				},
				{
					"group": "WebSocket Support",
					"methods": [
						{
							"method": "ws",
							"signature": "ws(path, [opts], handler)",
							"description": "Register a WebSocket upgrade handler for a path. The handler receives `(ws, req)` where `ws` is a `WebSocketConnection` instance with methods like `send()`, `sendJSON()`, `on()`, and `close()`.",
							"methodParams": [
								{
									"param": "path",
									"type": "string",
									"required": "Yes",
									"notes": "URL path to listen for upgrade requests."
								},
								{
									"param": "opts",
									"type": "object | Function",
									"required": "No",
									"notes": "Options object, or the handler function directly."
								},
								{
									"param": "handler",
									"type": "Function",
									"required": "Yes",
									"notes": "`(ws, req) => void`."
								}
							],
							"methodOptions": [
								{
									"option": "maxPayload",
									"type": "number",
									"default": "1048576",
									"notes": "Maximum incoming frame size in bytes (default 1 MB)."
								},
								{
									"option": "pingInterval",
									"type": "number",
									"default": "30000",
									"notes": "Auto-ping interval in ms. Set `0` to disable."
								},
								{
									"option": "verifyClient",
									"type": "Function",
									"default": "—",
									"notes": "`(req) => boolean` — return false to reject the upgrade."
								}
							]
						}
					]
				},
				{
					"group": "Route Introspection",
					"methods": [
						{
							"method": "routes",
							"signature": "routes()",
							"description": "Return a flat list of all registered routes across the router tree, including mounted sub-routers.  Useful for debugging, auto-generated docs, or CLI tooling.",
							"methodReturns": {
								"type": "{ method: string, path: string }[]",
								"description": "Flat array of route entries including WebSocket handlers."
							}
						}
					]
				},
