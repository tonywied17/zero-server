						},
						{
							"method": "ping",
							"signature": "ping([payload], [cb])",
							"description": "Send a ping frame.",
							"methodParams": [
								{
									"param": "payload",
									"type": "string | Buffer",
									"required": "No",
									"notes": "Optional payload (max 125 bytes)."
								},
								{
									"param": "cb",
									"type": "Function",
									"required": "No",
									"notes": "Called after the frame is flushed."
								}
							],
							"methodReturns": {
								"type": "boolean",
								"description": "`false` if the connection is not open."
							}
						},
						{
							"method": "pong",
							"signature": "pong([payload], [cb])",
							"description": "Send a pong frame.",
							"methodParams": [
								{
									"param": "payload",
									"type": "string | Buffer",
									"required": "No",
									"notes": "Optional payload."
								},
								{
									"param": "cb",
									"type": "Function",
									"required": "No",
									"notes": "Called after the frame is flushed."
								}
							],
							"methodReturns": {
								"type": "boolean",
								"description": "`false` if the connection is not open."
							}
						},
						{
							"method": "close",
							"signature": "close([code], [reason])",
							"description": "Close the WebSocket connection.",
							"methodParams": [
								{
									"param": "code",
									"type": "number",
									"required": "No",
									"notes": "Close status code."
								},
								{
									"param": "reason",
									"type": "string",
									"required": "No",
									"notes": "Close reason string."
								}
							]
						},
						{
							"method": "terminate",
							"signature": "terminate()",
							"description": "Forcefully destroy the underlying socket without a close frame."
						}
