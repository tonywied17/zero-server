		{
			"name": "SSE (Server-Sent Events)",
			"description": "SSE (Server-Sent Events) stream controller. Wraps a raw HTTP response and provides the full SSE text protocol. Tracks connection state, event counts, and bytes sent. Emits `'close'` when the client disconnects and `'error'` on write failures.",
			"example": "  app.get('/events', (req, res) => {\r\n      const stream = res.sse();           // opens SSE connection\r\n\n      stream.send({ hello: 'world' });    // unnamed event\r\n      stream.event('update', { id: 1 });  // named event\r\n      stream.retry(3000);                 // set client reconnect delay\r\n      stream.keepAlive(15000);            // auto-ping every 15s\r\n\n      stream.on('close', () => {\r\n          console.log('client disconnected after', stream.uptime, 'ms');\r\n      });\r\n  });",
			"options": [
				{
					"option": "secure",
					"type": "boolean",
					"default": "—",
					"notes": "Whether the connection is over TLS."
				},
				{
					"option": "autoId",
					"type": "boolean",
					"default": "—",
					"notes": "Auto-increment event IDs."
				},
				{
					"option": "startId",
					"type": "number",
					"default": "—",
					"notes": "Starting value for auto-ID (default 1)."
				},
				{
					"option": "lastEventId",
					"type": "string",
					"default": "—",
					"notes": "Last-Event-ID from the client reconnection header."
				},
				{
					"option": "keepAlive",
					"type": "number",
					"default": "—",
					"notes": "Interval (ms) for automatic keep-alive pings. 0 to disable."
				},
				{
					"option": "keepAliveComment",
					"type": "string",
					"default": "—",
					"notes": "Comment text for keep-alive pings (default `'ping'`)."
				}
			],
			"params": [
				{
					"param": "raw",
					"type": "import('http').ServerResponse",
					"required": "Yes",
					"notes": "Raw HTTP response stream."
				}
			],
