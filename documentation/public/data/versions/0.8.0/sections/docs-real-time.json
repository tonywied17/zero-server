		{
			"name": "WebSocket",
			"description": "Full-featured WebSocket connection wrapper over a raw TCP socket. Implements RFC 6455 framing for text, binary, ping, pong, and close.",
			"options": [
				{
					"option": "maxPayload",
					"type": "number",
					"default": "1048576",
					"notes": "Maximum incoming frame size in bytes."
				},
				{
					"option": "pingInterval",
					"type": "number",
					"default": "30000",
					"notes": "Auto-ping interval in ms (0 to disable)."
				},
				{
					"option": "protocol",
					"type": "string",
					"default": "—",
					"notes": "Negotiated WebSocket sub-protocol."
				},
				{
					"option": "extensions",
					"type": "string",
					"default": "—",
					"notes": "Negotiated WebSocket extensions."
				},
				{
					"option": "headers",
					"type": "object",
					"default": "—",
					"notes": "HTTP headers from the upgrade request."
				},
				{
					"option": "ip",
					"type": "string",
					"default": "—",
					"notes": "Remote IP address of the client."
				},
				{
					"option": "query",
					"type": "object",
					"default": "—",
					"notes": "Parsed query-string parameters from the upgrade URL."
				},
				{
					"option": "url",
					"type": "string",
					"default": "—",
					"notes": "The request URL path."
				},
				{
					"option": "secure",
					"type": "boolean",
					"default": "false",
					"notes": "Whether the connection is over TLS."
				}
			],
			"params": [
				{
					"param": "socket",
					"type": "import('net').Socket",
					"required": "Yes",
					"notes": "The upgraded TCP socket."
				},
				{
					"param": "meta",
					"type": "object",
					"required": "No",
					"notes": "Connection metadata from the upgrade handshake."
				}
			],
