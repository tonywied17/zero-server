				{
					"group": "Sending",
					"methods": [
						{
							"method": "send",
							"signature": "send(data, [opts])",
							"description": "Send a text or binary message.",
							"methodParams": [
								{
									"param": "data",
									"type": "string | Buffer",
									"required": "Yes",
									"notes": "Payload."
								},
								{
									"param": "opts",
									"type": "object",
									"required": "No",
									"notes": "Configuration options."
								}
							],
							"methodOptions": [
								{
									"option": "binary",
									"type": "boolean",
									"default": "—",
									"notes": "Force binary frame (opcode 0x02)."
								},
								{
									"option": "callback",
									"type": "Function",
									"default": "—",
									"notes": "Called after the data is flushed."
								}
							],
							"methodReturns": {
								"type": "boolean",
								"description": "`false` if the socket buffer is full (backpressure)."
							}
						},
						{
							"method": "sendJSON",
							"signature": "sendJSON(obj, [cb])",
							"description": "Send a JSON-serialised message (sets text frame).",
							"methodParams": [
								{
									"param": "obj",
									"type": "*",
									"required": "Yes",
									"notes": "Value to serialise."
								},
								{
									"param": "cb",
									"type": "Function",
									"required": "No",
									"notes": "Called after the data is flushed."
								}
							],
							"methodReturns": {
								"type": "boolean",
								"description": "`false` if the connection is not open or serialisation fails."
