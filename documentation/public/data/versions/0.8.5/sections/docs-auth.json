									"required": "Yes",
									"notes": "HMAC secret or RSA private key (PEM)."
								},
								{
									"param": "opts",
									"type": "object",
									"required": "No",
									"notes": "Signing options."
								}
							],
							"methodOptions": [
								{
									"option": "algorithm",
									"type": "string",
									"default": "'HS256'",
									"notes": "Signing algorithm."
								},
								{
									"option": "expiresIn",
									"type": "number",
									"default": "—",
									"notes": "Expiry in seconds from now."
								},
								{
									"option": "issuer",
									"type": "string",
									"default": "—",
									"notes": "`iss` claim."
								},
								{
									"option": "audience",
									"type": "string",
									"default": "—",
									"notes": "`aud` claim."
								},
								{
									"option": "subject",
									"type": "string",
									"default": "—",
									"notes": "`sub` claim."
								},
								{
									"option": "jwtId",
									"type": "string",
									"default": "—",
									"notes": "`jti` claim."
