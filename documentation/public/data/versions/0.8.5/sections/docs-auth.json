								{
									"option": "algorithm",
									"type": "string",
									"default": "'HS256'",
									"notes": "Signing algorithm."
								}
							],
							"methodReturns": {
								"type": "{ generateTokens: Function, verifyRefreshToken: Function, verifyAccessToken: Function }",
								"description": ""
							}
						},
						{
							"method": "createRefreshToken",
							"signature": "createRefreshToken(payload, secret, [opts])",
							"description": "Generate a signed refresh token. Refresh tokens are long-lived and should be stored securely.",
							"methodParams": [
								{
									"param": "payload",
									"type": "object",
									"required": "Yes",
									"notes": "Claims (typically `{ sub, jti }`)."
								},
								{
									"param": "secret",
									"type": "string | Buffer",
									"required": "Yes",
									"notes": "Signing secret."
								},
								{
									"param": "opts",
									"type": "object",
									"required": "No",
									"notes": "Options."
								}
							],
							"methodOptions": [
								{
									"option": "expiresIn",
									"type": "number",
									"default": "604800",
									"notes": "Expiry in seconds (default: 7 days)."
								},
								{
									"option": "algorithm",
									"type": "string",
									"default": "'HS256'",
									"notes": "Signing algorithm."
								}
							],
							"methodReturns": {
								"type": "string",
								"description": "Signed refresh token (JWT)."
							}
						}
					]
				}
			]
		},
		{
			"name": "session",
			"description": "Zero-dependency session middleware. Supports encrypted cookie sessions (stateless, AES-256-GCM) and server-side session stores (memory and custom adapters). Cookie sessions embed the entire session in an encrypted cookie, so no server-side storage is needed.  Server-side sessions store only a session ID in the cookie, keeping data on the server.",
			"example": "  // Encrypted cookie session (stateless)\r\n  app.use(session({ secret: process.env.SESSION_SECRET }));",
			"params": [
				{
					"param": "id",
					"type": "string",
					"required": "Yes",
					"notes": "Session ID."
				},
				{
					"param": "data",
					"type": "object",
					"required": "No",
					"notes": "Initial data."
				}
			],
			"methodGroups": [
				{
					"group": "Session class",
					"methods": [
						{
							"method": "get",
							"signature": "get(key)",
							"description": "Get a session value by key.",
							"methodParams": [
								{
									"param": "key",
									"type": "string",
									"required": "Yes",
									"notes": ""
								}
							],
							"methodReturns": {
								"type": "*",
								"description": ""
							}
						},
						{
							"method": "set",
							"signature": "set(key, value)",
							"description": "Set a session value.",
							"methodParams": [
								{
									"param": "key",
									"type": "string",
									"required": "Yes",
									"notes": ""
								},
								{
									"param": "value",
									"type": "*",
									"required": "Yes",
									"notes": ""
								}
							],
							"methodReturns": {
								"type": "Session",
								"description": "this (chainable)"
							}
						},
						{
							"method": "has",
							"signature": "has(key)",
							"description": "Check if a key exists in the session.",
							"methodParams": [
								{
									"param": "key",
									"type": "string",
									"required": "Yes",
									"notes": ""
								}
							],
							"methodReturns": {
								"type": "boolean",
								"description": ""
							}
						},
						{
							"method": "delete",
							"signature": "delete(key)",
							"description": "Delete a session key.",
							"methodParams": [
								{
									"param": "key",
									"type": "string",
									"required": "Yes",
									"notes": ""
								}
							],
							"methodReturns": {
								"type": "boolean",
								"description": "true if the key existed."
							}
						},
						{
							"method": "all",
							"signature": "all()",
							"description": "Get all session data as a plain object.",
							"methodReturns": {
								"type": "object",
								"description": ""
							}
						},
						{
							"method": "size",
							"signature": "size()",
							"description": "Number of session entries.",
							"methodReturns": {
								"type": "number",
								"description": ""
							}
						},
						{
							"method": "clear",
							"signature": "clear()",
							"description": "Clear all session data.",
							"methodReturns": {
								"type": "Session",
								"description": ""
							}
						},
						{
							"method": "destroy",
							"signature": "destroy()",
							"description": "Destroy the session. Clears all data and marks cookie for expiry."
						},
						{
							"method": "regenerate",
							"signature": "regenerate()",
							"description": "Regenerate the session ID (prevents session fixation). Preserves existing data under a new ID."
						},
						{
							"method": "flash",
							"signature": "flash(key, value)",
							"description": "Set a flash message (available only on the next request).",
							"methodParams": [
								{
									"param": "key",
									"type": "string",
									"required": "Yes",
									"notes": "Flash key (e.g. `'success'`, `'error'`)."
								},
								{
									"param": "value",
									"type": "*",
									"required": "Yes",
									"notes": "Flash value."
								}
							],
							"methodReturns": {
								"type": "Session",
								"description": ""
							}
						},
						{
							"method": "flashes",
							"signature": "flashes([key])",
							"description": "Read flash messages for a key (consumes them).",
							"methodParams": [
								{
									"param": "key",
									"type": "string",
									"required": "No",
									"notes": "Flash key. If omitted, returns all flashes."
								}
							],
							"methodReturns": {
								"type": "*[] | object",
								"description": "Array of messages for key, or object of all flashes."
							}
						}
					]
				},
