				{
					"group": "Session Middleware",
					"methods": [
						{
							"method": "session",
							"signature": "session(opts)",
							"description": "Create session middleware. Two modes: 1. **Cookie session** (no `store`): Entire session encrypted in a cookie. Great for small payloads (< 4 KB). Zero server state. 2. **Server-side session** (with `store`): Only session ID in cookie, data lives in the store. Scales to large payloads.",
							"methodParams": [
								{
									"param": "opts",
									"type": "object",
									"required": "Yes",
									"notes": "Configuration."
								}
							],
							"methodOptions": [
								{
									"option": "secret",
									"type": "string | string[]",
									"default": "—",
									"notes": "Encryption secret(s). First secret used for\nencryption, all are tried for decryption (supports rotation)."
								},
								{
									"option": "store",
									"type": "object",
									"default": "—",
									"notes": "Server-side session store (must implement `get`, `set`, `destroy`)."
								},
								{
									"option": "name",
									"type": "string",
									"default": "'sid'",
									"notes": "Cookie name."
								},
								{
									"option": "cookie",
									"type": "object",
									"default": "—",
									"notes": "Cookie options."
								},
								{
									"option": "cookie.maxAge",
									"type": "number",
									"default": "86400000",
									"notes": "Cookie max-age in ms (default 24h)."
								},
								{
									"option": "cookie.path",
									"type": "string",
									"default": "'/'",
									"notes": "Cookie path."
								},
								{
									"option": "cookie.domain",
									"type": "string",
									"default": "—",
									"notes": "Cookie domain."
								},
								{
									"option": "cookie.secure",
									"type": "boolean",
									"default": "—",
									"notes": "Secure-only flag (default: auto-detect via `req.secure`)."
								},
								{
									"option": "cookie.httpOnly",
									"type": "boolean",
									"default": "true",
									"notes": "HttpOnly flag."
								},
								{
									"option": "cookie.sameSite",
									"type": "string",
									"default": "'Lax'",
									"notes": "SameSite attribute."
								},
								{
									"option": "rolling",
									"type": "boolean",
									"default": "false",
									"notes": "Reset cookie maxAge on every response."
								},
								{
									"option": "genid",
									"type": "Function",
									"default": "—",
									"notes": "Custom session ID generator."
								}
							],
							"methodReturns": {
								"type": "Function",
								"description": "Middleware `(req, res, next) => void`."
							}
						}
					]
				}
			]
		},
		{
