							"methodReturns": {
								"type": "string",
								"description": "Signed JWT."
							}
						},
						{
							"method": "verify",
							"signature": "verify(token, secretOrKey, [opts])",
							"description": "Verify a JWT signature and validate claims.",
							"methodParams": [
								{
									"param": "token",
									"type": "string",
									"required": "Yes",
									"notes": "Raw JWT string."
								},
								{
									"param": "secretOrKey",
									"type": "string | Buffer",
									"required": "Yes",
									"notes": "HMAC secret or RSA public key (PEM)."
								},
								{
									"param": "opts",
									"type": "object",
									"required": "No",
									"notes": "Verification options."
								}
							],
							"methodOptions": [
								{
									"option": "algorithms",
									"type": "string | string[]",
									"default": "—",
									"notes": "Allowed algorithms. Default: inferred from key type."
								},
								{
									"option": "audience",
									"type": "string | string[]",
									"default": "—",
									"notes": "Required `aud` claim."
								},
								{
									"option": "issuer",
									"type": "string | string[]",
									"default": "—",
									"notes": "Required `iss` claim."
								},
								{
									"option": "subject",
									"type": "string",
									"default": "—",
									"notes": "Required `sub` claim."
								},
								{
									"option": "clockTolerance",
									"type": "number",
									"default": "0",
									"notes": "Seconds of clock skew tolerance for `exp`/`nbf`."
								},
								{
									"option": "maxAge",
									"type": "number",
									"default": "—",
									"notes": "Maximum token age in seconds (from `iat`)."
								},
								{
									"option": "ignoreExpiration",
									"type": "boolean",
									"default": "false",
									"notes": "Skip expiry validation."
								}
							],
							"methodReturns": {
								"type": "{ header: object, payload: object }",
								"description": "Decoded and verified token."
							}
						}
					]
				},
				{
					"group": "JWKS Support",
					"methods": [
						{
							"method": "jwks",
							"signature": "jwks(jwksUri, [opts])",
							"description": "Create a JWKS key provider that fetches and caches public keys. Auto-refreshes keys when a `kid` is not found.",
							"methodParams": [
								{
									"param": "jwksUri",
									"type": "string",
									"required": "Yes",
									"notes": "URL of the JWKS endpoint."
