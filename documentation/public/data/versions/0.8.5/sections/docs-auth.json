{
	"section": "Authentication & Sessions",
	"icon": "lock",
	"items": [
		{
			"name": "jwt",
			"description": "Zero-dependency JWT (JSON Web Token) middleware. Supports HMAC (HS256/384/512) and RSA (RS256/384/512) algorithms, JWKS endpoint auto-fetching, token extraction from header/cookie/query, and configurable validation rules. Populates `req.user` with the decoded payload and `req.token` with the raw token string.",
			"params": [
				{
					"param": "token",
					"type": "string",
					"required": "Yes",
					"notes": "Raw JWT string."
				}
			],
			"returns": {
				"type": "{ header: object, payload: object, signature: string } | null",
				"description": ""
			},
			"example": "  const { createApp, jwt } = require('zero-http');\r\n  const app = createApp();\r\n\n  app.use(jwt({ secret: process.env.JWT_SECRET }));",
			"methodGroups": [
				{
					"group": "JWT Middleware",
					"methods": [
						{
							"method": "jwt",
							"signature": "jwt(opts)",
							"description": "Create JWT authentication middleware. On success, populates: - `req.user` — decoded payload - `req.auth` — `{ header, payload, token }` full decode info - `req.token` — raw JWT string",
							"methodParams": [
								{
									"param": "opts",
									"type": "object",
									"required": "Yes",
									"notes": "Configuration."
								}
							],
							"methodOptions": [
								{
									"option": "secret",
									"type": "string | Buffer",
									"default": "—",
									"notes": "HMAC secret for HS* algorithms."
								},
								{
									"option": "publicKey",
									"type": "string | Buffer",
									"default": "—",
									"notes": "RSA public key (PEM) for RS* algorithms."
								},
								{
									"option": "getKey",
									"type": "Function",
									"default": "—",
									"notes": "Dynamic key resolver `async (header, payload) => key`. Overrides `secret`/`publicKey`."
								},
								{
									"option": "jwksUri",
									"type": "string",
									"default": "—",
									"notes": "JWKS endpoint URL (creates a `getKey` automatically)."
								},
								{
									"option": "algorithms",
									"type": "string | string[]",
									"default": "—",
									"notes": "Allowed algorithms. Default: auto-detect."
								},
								{
									"option": "getToken",
									"type": "Function",
									"default": "—",
									"notes": "Custom token extractor `(req) => string|null`."
								},
								{
									"option": "tokenLocation",
									"type": "string",
									"default": "'header'",
									"notes": "Where to look: `'header'`, `'cookie'`, `'query'`."
								},
								{
									"option": "cookieName",
									"type": "string",
									"default": "'token'",
									"notes": "Cookie name when `tokenLocation='cookie'`."
								},
								{
									"option": "queryParam",
									"type": "string",
									"default": "'token'",
									"notes": "Query param name when `tokenLocation='query'`."
								},
								{
									"option": "audience",
									"type": "string | string[]",
									"default": "—",
									"notes": "Required `aud` claim."
								},
								{
									"option": "issuer",
									"type": "string | string[]",
									"default": "—",
									"notes": "Required `iss` claim."
								},
								{
									"option": "subject",
									"type": "string",
									"default": "—",
									"notes": "Required `sub` claim."
								},
								{
									"option": "clockTolerance",
									"type": "number",
									"default": "0",
									"notes": "Clock skew tolerance in seconds."
								},
								{
									"option": "maxAge",
									"type": "number",
									"default": "—",
									"notes": "Maximum token age in seconds."
								},
								{
									"option": "credentialsRequired",
									"type": "boolean",
									"default": "true",
									"notes": "Return 401 if no token found (false = optional auth)."
								},
								{
									"option": "isRevoked",
									"type": "Function",
									"default": "—",
									"notes": "`async (payload) => boolean` — check token revocation."
								},
								{
									"option": "onError",
									"type": "Function",
									"default": "—",
									"notes": "Custom error handler `(err, req, res) => void`."
								}
							],
							"methodReturns": {
								"type": "Function",
								"description": "Middleware `(req, res, next) => void`."
							}
						}
					]
				},
				{
