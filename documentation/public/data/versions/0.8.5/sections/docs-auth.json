								{
									"param": "opts",
									"type": "object",
									"required": "No",
									"notes": "Options."
								}
							],
							"methodOptions": [
								{
									"option": "fetcher",
									"type": "Function",
									"default": "—",
									"notes": "Custom fetch function (default: built-in fetch)."
								},
								{
									"option": "cacheTtl",
									"type": "number",
									"default": "600000",
									"notes": "Cache TTL in ms (default 10 minutes)."
								},
								{
									"option": "requestTimeout",
									"type": "number",
									"default": "5000",
									"notes": "Request timeout in ms."
								}
							],
							"methodReturns": {
								"type": "Function",
								"description": "`async (header) => publicKey` — resolves the signing key for a JWT header."
							}
						}
					]
				},
				{
					"group": "Token Refresh Helpers",
					"methods": [
						{
							"method": "tokenPair",
							"signature": "tokenPair(config)",
							"description": "Create a token-pair factory for convenient access + refresh token generation.",
							"methodParams": [
								{
									"param": "config",
									"type": "object",
									"required": "Yes",
									"notes": "Configuration."
								}
							],
							"methodOptions": [
								{
									"option": "accessSecret",
									"type": "string | Buffer",
									"default": "—",
									"notes": "Secret for access tokens."
								},
								{
									"option": "refreshSecret",
									"type": "string | Buffer",
									"default": "—",
									"notes": "Secret for refresh tokens (defaults to accessSecret)."
								},
								{
									"option": "accessExpiresIn",
									"type": "number",
									"default": "900",
									"notes": "Access token expiry in seconds (default: 15 min)."
