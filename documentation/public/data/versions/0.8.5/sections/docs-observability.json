					"type": "number",
					"default": "—",
					"notes": "Max RSS in bytes."
				}
			],
			"returns": {
				"type": "Function",
				"description": "Check function."
			},
			"example": "  const { healthCheck } = require('zero-http');\r\n\n  app.get('/healthz', healthCheck());\r\n  app.get('/readyz', healthCheck({\r\n      checks: {\r\n          database: () => db.ping(),\r\n          cache: () => redis.ping(),\r\n      },\r\n  }));",
			"methodGroups": [
				{
					"group": "Health Check Handler",
					"methods": [
						{
							"method": "healthCheck",
							"signature": "healthCheck([opts])",
							"description": "Create a health check route handler. Returns a JSON response with the status of all registered checks. Returns `200` when all checks pass, `503` when any check fails or when the application is in drain/shutdown state. Response format: ```json { \"status\": \"healthy\", \"uptime\": 12345, \"timestamp\": \"2026-01-01T00:00:00.000Z\", \"checks\": { \"database\": { \"healthy\": true, \"duration\": 5, \"details\": {} } } } ```",
							"methodParams": [
								{
									"param": "opts",
									"type": "object",
									"required": "No",
									"notes": "Options."
								}
							],
							"methodOptions": [
								{
									"option": "checks",
									"type": "Object<string, Function>",
									"default": "—",
									"notes": "Named check functions. Each returns `{ healthy, details }` or a boolean/Promise."
								},
								{
									"option": "timeout",
									"type": "number",
									"default": "5000",
									"notes": "Max time to wait for all checks in ms."
								},
								{
									"option": "verbose",
									"type": "boolean",
									"default": "true",
									"notes": "Include check details in response."
								},
								{
									"option": "onFailure",
									"type": "Function",
									"default": "—",
									"notes": "`(results) => void` — called when any check fails."
								}
							],
							"methodReturns": {
								"type": "Function",
								"description": "Route handler `(req, res) => void`."
							}
						}
					]
				},
