				{
					"group": "Structured Logger Middleware",
					"methods": [
						{
							"method": "structuredLogger",
							"signature": "structuredLogger([opts])",
							"description": "Create structured request-logging middleware. Automatically logs every completed request with: `requestId`, `method`, `url`, `status`, `duration`, `ip`, `userAgent`, and `contentLength`. Also attaches `req.log` — a child logger with bound request context so handlers can log with full correlation.",
							"methodParams": [
								{
									"param": "opts",
									"type": "object",
									"required": "No",
									"notes": "Configuration options."
								}
							],
							"methodOptions": [
								{
									"option": "level",
									"type": "string | number",
									"default": "'info'",
									"notes": "Minimum log level. Default follows NODE_ENV."
								},
								{
									"option": "format",
									"type": "'json' | 'pretty'",
									"default": "—",
									"notes": "Output format. `'json'` for production, `'pretty'` for dev. Default: `'json'` in production, `'pretty'` otherwise."
								},
								{
									"option": "transport",
									"type": "Function",
									"default": "—",
									"notes": "Custom transport `(entry) => void` for each log entry."
								},
								{
									"option": "colors",
									"type": "boolean",
									"default": "—",
									"notes": "ANSI colors (default: TTY detection). Only applies to pretty format."
								},
								{
									"option": "timestamps",
									"type": "boolean",
									"default": "true",
									"notes": "Include timestamps."
								},
								{
									"option": "stream",
									"type": "WritableStream",
									"default": "—",
									"notes": "Output stream override."
								},
								{
									"option": "skip",
									"type": "Function",
									"default": "—",
									"notes": "`(req, res) => boolean` — skip logging for certain requests."
								},
								{
									"option": "customFields",
									"type": "Function",
									"default": "—",
									"notes": "`(req, res) => object` — extra fields to merge into each request log entry."
								},
								{
									"option": "msg",
									"type": "string",
									"default": "—",
									"notes": "Custom message template. Supports placeholders: `:method`, `:url`, `:status`, `:duration`."
								}
							],
							"methodReturns": {
								"type": "Function",
								"description": "Middleware `(req, res, next) => void`."
							}
						}
					]
				}
			]
		},
		{
			"name": "MetricsRegistry",
			"description": "Zero-dependency metrics registry with Prometheus-compatible text exposition format. Provides Counter, Gauge, and Histogram metric types with label support, automatic HTTP instrumentation middleware, and a handler for `/metrics` endpoints.",
			"example": "  const { MetricsRegistry, metricsMiddleware } = require('zero-http');\r\n\n  const registry = new MetricsRegistry();\r\n  app.use(metricsMiddleware({ registry }));\r\n  app.get('/metrics', (req, res) => {\r\n      res.set('Content-Type', 'text/plain; version=0.04');\r\n      res.send(registry.metrics());\r\n  });",
			"options": [
				{
					"option": "name",
					"type": "string",
					"default": "—",
					"notes": "Metric name (snake_case recommended)."
				},
				{
					"option": "help",
					"type": "string",
					"default": "—",
					"notes": "Human-readable description."
				},
				{
					"option": "labels",
					"type": "string[]",
					"default": "[",
					"notes": "] - Label names."
				}
			],
